import java.util.*;

class Student {
    int id;
    String name;
    int marks;

    Student(int id, String name, int marks) {
        this.id = id;
        this.name = name;
        this.marks = marks;
    }
}

public class StudentSystem {
    static List<Student> list = new ArrayList<>();

    static void add(Student s) {
        list.add(s);
    }

    static void delete(int id) {
        list.removeIf(s -> s.id == id);
    }

    static void search(int id) {
        for (Student s : list) {
            if (s.id == id) {
                System.out.println(s.name + " " + s.marks);
            }
        }
    }

    static void sortByMarks() {
        list.sort((a, b) -> b.marks - a.marks);
        for (Student s : list) {
            System.out.println(s.name + " " + s.marks);
        }
    }

    public static void main(String[] args) {
        add(new Student(1, "A", 80));
        add(new Student(2, "B", 90));

        search(1);
        sortByMarks();
        delete(1);
    }
}
